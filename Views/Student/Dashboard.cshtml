@model IEnumerable<StudentAdmissionSystem.Models.Student>
@{
    ViewData["Title"] = "Student Details";
}

<style>/* ── STATS CARDS ── */
.stats-grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 15px;
margin-bottom: 25px;
}

.stat-card {
background: #FAEEDA;
border: 1px solid #BA7517;
padding: 14px;
border-radius: 6px;
transition: 0.2s;
}

.stat-card:hover {
transform: translateY(-2px);
box-shadow: 0 4px 10px rgba(186, 117, 23, 0.2);
}

.stat-title {
font-size: 10px;
color: #854F0B;
text-transform: uppercase;
letter-spacing: 1px;
}

.stat-value {
font-size: 22px;
font-weight: 700;
color: #2C2C2A;
margin-top: 5px;
}
</style>
<!-- STATS CARDS -->
<div class="stats-grid">

    <div class="stat-card">
        <div class="stat-title">Total Students</div>
        <div class="stat-value">@ViewBag.TotalStudents</div>
    </div>

    <div class="stat-card">
        <div class="stat-title">Total Courses</div>
        <div class="stat-value">@ViewBag.TotalCourses</div>
    </div>

    <div class="stat-card">
        <div class="stat-title">Total Admissions</div>
        <div class="stat-value">@ViewBag.TotalAdmissions</div>
    </div>

</div>